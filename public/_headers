# Applied by Cloudflare's static-asset layer to every response served
# from public/ -- this covers HTML pages, JS, and CSS. It does NOT cover
# API responses the Worker constructs directly (those get the identical
# header set via SECURITY_HEADERS in src/lib/core.js's json()/corsJson()).
# See docs/SECURITY_HEADERS.md for why both mechanisms are needed and
# what each one covers.
#
# Keep this policy in sync with SECURITY_HEADERS in src/lib/core.js.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=15552000
  Permissions-Policy: geolocation=(), microphone=(), camera=(self), payment=(self)
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'
